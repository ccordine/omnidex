APP_ENV=development
LISTEN_ADDR=0.0.0.0:8090
# Public URL for this machine on your LAN (Admin → Network access can override in DB)
CORE_URL=http://192.168.1.102:8090

# Use bundled postgres service:
DATABASE_URL=postgres://agent:agent@postgres:5432/agent?sslmode=disable

# Or point at your existing rooms-ai postgres/pgvector instance instead:
# DATABASE_URL=postgres://<user>:<pass>@host.docker.internal:5432/<db>?sslmode=disable

LLM_PROVIDER=ollama

# If Ollama runs on your host machine:
# Linux: ensure Ollama listens beyond loopback (OLLAMA_HOST=0.0.0.0:11434)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_MODEL_FAST=qwen2.5-coder:7b
OLLAMA_MODEL_REASONING=qwen2.5:7b
OLLAMA_MODEL_TAGGER=qwen2.5:7b
OLLAMA_MODEL_PLANNER=qwen2.5-coder:14b
OLLAMA_MODEL_ANALYZER=qwen2.5:7b
OLLAMA_MODEL_RESPONDER=qwen2.5-coder:7b
OLLAMA_MODEL_SEARCH=qwen2.5:7b
OLLAMA_MODEL_MEMORY=qwen2.5:7b
OLLAMA_MODEL_EVALUATOR=qwen2.5:7b
OLLAMA_MODEL_SPECIALIST_PLANNER=llama3.2
OLLAMA_MODEL_SPECIALIST_TOOLING=llama3.2
OLLAMA_MODEL_SPECIALIST_FILESYSTEM_RESEARCH=llama3.2
OLLAMA_MODEL_SPECIALIST_INTENT_TAGGING=llama3.2
OLLAMA_MODEL_SPECIALIST_MEMORY_RETRIEVAL=llama3.2
OLLAMA_MODEL_SPECIALIST_WEB_RESEARCH=llama3.2
OLLAMA_MODEL_SPECIALIST_ANALYSIS=llama3.2
OLLAMA_MODEL_SPECIALIST_RESPONSE=llama3.2
OLLAMA_MODEL_SPECIALIST_REVIEW_VERIFICATION=llama3.2
OLLAMA_MODEL_SPECIALIST_MEDIA_CONTROL=llama3.2
OLLAMA_MODEL_SPECIALIST_BROWSER_INSPECTION=llama3.2
OLLAMA_MODEL_SPECIALIST_SCREEN_VISION=llama3.2
OLLAMA_MODEL_SPECIALIST_SHELL_EXECUTION=qwen2.5-coder:7b
OLLAMA_MODEL_SPECIALIST_AUDIO_NOTES=llama3.2
EMBEDDING_MODEL=nomic-embed-text

# To use OpenAI instead of Ollama, set LLM_PROVIDER=openai and configure:
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODEL_FAST=
OPENAI_MODEL_REASONING=
OPENAI_MODEL_TAGGER=
OPENAI_MODEL_PLANNER=
OPENAI_MODEL_ANALYZER=
OPENAI_MODEL_RESPONDER=
OPENAI_MODEL_SEARCH=
OPENAI_MODEL_MEMORY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# To use Microsoft Azure AI, set LLM_PROVIDER=azure, microsoft, windows-ai, or azure-openai and configure:
# API styles: v1 for /openai/v1 OpenAI-compatible Azure APIs, azure_openai for deployment routes, foundry for /models endpoints.
AZURE_AI_BASE_URL=
AZURE_OPENAI_ENDPOINT=
AZURE_AI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_AI_API_VERSION=
AZURE_AI_API_STYLE=
AZURE_AI_MODEL=
AZURE_OPENAI_DEPLOYMENT=
AZURE_AI_MODEL_FAST=
AZURE_AI_MODEL_REASONING=
AZURE_AI_MODEL_TAGGER=
AZURE_AI_MODEL_PLANNER=
AZURE_AI_MODEL_ANALYZER=
AZURE_AI_MODEL_RESPONDER=
AZURE_AI_MODEL_SEARCH=
AZURE_AI_MODEL_MEMORY=
AZURE_AI_EMBEDDING_MODEL=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=

# To use xAI Grok, set LLM_PROVIDER=xai, grok, or grock and configure:
# xAI/Grok uses an OpenAI-compatible chat completions API. Embeddings should remain on ollama, openai, google, or huggingface.
XAI_BASE_URL=https://api.x.ai/v1
XAI_API_KEY=
GROK_API_KEY=
XAI_MODEL=grok-4.3
XAI_MODEL_FAST=
XAI_MODEL_REASONING=
XAI_MODEL_TAGGER=
XAI_MODEL_PLANNER=
XAI_MODEL_ANALYZER=
XAI_MODEL_RESPONDER=
XAI_MODEL_SEARCH=
XAI_MODEL_MEMORY=
XAI_EMBEDDING_PROVIDER=ollama

# To use Google Gemini, set LLM_PROVIDER=google or gemini and configure:
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_MODEL_FAST=
GOOGLE_MODEL_REASONING=
GOOGLE_MODEL_TAGGER=
GOOGLE_MODEL_PLANNER=
GOOGLE_MODEL_ANALYZER=
GOOGLE_MODEL_RESPONDER=
GOOGLE_MODEL_SEARCH=
GOOGLE_MODEL_MEMORY=
GOOGLE_EMBEDDING_MODEL=text-embedding-004

# To use Anthropic Claude, set LLM_PROVIDER=anthropic or claude and configure.
# Anthropic does not provide embeddings; keep EMBEDDING_PROVIDER on ollama, openai, google, or huggingface.
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MODEL_FAST=
ANTHROPIC_MODEL_REASONING=
ANTHROPIC_MODEL_TAGGER=
ANTHROPIC_MODEL_PLANNER=
ANTHROPIC_MODEL_ANALYZER=
ANTHROPIC_MODEL_RESPONDER=
ANTHROPIC_MODEL_SEARCH=
ANTHROPIC_MODEL_MEMORY=
ANTHROPIC_EMBEDDING_PROVIDER=ollama

# To use Hugging Face Inference Providers, set LLM_PROVIDER=huggingface or hf and configure:
HUGGINGFACE_BASE_URL=https://router.huggingface.co
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=openai/gpt-oss-20b:fastest
HUGGINGFACE_MODEL_FAST=
HUGGINGFACE_MODEL_REASONING=
HUGGINGFACE_MODEL_TAGGER=
HUGGINGFACE_MODEL_PLANNER=
HUGGINGFACE_MODEL_ANALYZER=
HUGGINGFACE_MODEL_RESPONDER=
HUGGINGFACE_MODEL_SEARCH=
HUGGINGFACE_MODEL_MEMORY=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Optional: route embeddings through a different provider than generation.
# Useful for Anthropic, or to keep vector dimensions stable while trying different chat models.
EMBEDDING_PROVIDER=ollama

WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDERS=duckduckgo,google,reddit
WEB_SEARCH_TIMEOUT=15s
WEB_SEARCH_PER_SOURCE_BUDGET=3000
WEB_SEARCH_TOTAL_BUDGET=6000
WORKSPACE_SCAN_ENABLED=true
WORKSPACE_ROOT=/workspace
WORKSPACE_MAX_FILES=5000
WORKSPACE_CONTEXT_BUDGET=6000
STOP_ON_SUFFICIENT_CONTEXT=true
SUFFICIENT_CONTEXT_CHARS=1400
MEMORY_INFERENCE_ENABLED=true
MEMORY_INFERENCE_MAX_ITEMS=3
TOURNAMENT_ENABLED=true
TOURNAMENT_CHUNK_CHARS=2200
TOURNAMENT_SUMMARY_CHARS=750
TOURNAMENT_MAX_ROUNDS=4
TOURNAMENT_VERIFY_RELEVANCE=true

WORKER_COUNT=3
WORKER_POLL_INTERVAL=2s
REQUEST_TIMEOUT=90s
RETRIEVAL_LIMIT=8
CONTEXT_CHAR_BUDGET=4000
HALLUCINATION_RETRY_LIMIT=2
OMNI_EVALUATOR_THRESHOLD=70
OMNI_EVALUATOR_NUM_CTX=1024
# Internal thinking/pilot channel (isolated from user chat; visible in timeline as THK> events)
OMNI_THINKING_MODEL=qwen2.5:7b
OLLAMA_MODEL_THINKING=qwen2.5:7b
OMNI_THINKING_NUM_CTX=8192
OMNI_THINKING_MAX_STEPS=8
# OMNI_DISABLE_THINKING=true
# Optional explicit restart command chain for hallucination loops.
# Use "||" between fallbacks, for example:
# OLLAMA_RESTART_COMMAND=docker compose restart ollama || systemctl restart ollama
OLLAMA_RESTART_COMMAND=
OLLAMA_RESTART_TIMEOUT=20s
MIGRATE_ON_STARTUP=true
MIGRATIONS_DIR=migrations
OMNIDEX_V3_ENABLED=true
OMNIDEX_SKILLS_ROOT=skills
