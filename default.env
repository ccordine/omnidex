# Quickstart defaults for docker compose
# Usage:
#   cp default.env .env
#   docker compose up --build

APP_ENV=development
LISTEN_ADDR=0.0.0.0:8090
# LAN URL for phones/tablets on the same network (also editable in Admin → Network access)
CORE_URL=http://192.168.1.102:8090
WRAPPER_ONLY=false

# Core uses bundled postgres service from docker-compose.yml
DATABASE_URL=postgres://agent:agent@postgres:5432/agent?sslmode=disable

# Host bridge for native directory picker + host filesystem browse (Docker setups).
# On the host: omni host service install   (systemd user service, starts at login)
# Or manually: omni host serve --listen 0.0.0.0:8091
# Then point core at it:
HOST_AGENT_URL=http://host.docker.internal:8091
# HOST_AGENT_TOKEN=
# Browser terminal defaults to proxying through core (port 8090 only).
# For direct browser→bridge on port 8091 (lower latency, requires firewall open):
# OMNI_TERMINAL_DIRECT=true
# HOST_BRIDGE_PUBLIC_WS_URL=ws://192.168.1.102:8091

# Ollama running on host machine.
# Linux: ensure Ollama listens beyond loopback (OLLAMA_HOST=0.0.0.0:11434).
# Core auto-probes fallbacks at startup: OLLAMA_BASE_URL, OLLAMA_FALLBACK_URLS,
# host.docker.internal, the docker bridge gateway, then localhost.
# If a manual gateway IP stops working, remove it or set OLLAMA_BASE_URL back to host.docker.internal.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:4b-thinking
OLLAMA_MODEL_FAST=qwen2.5-coder:7b
OLLAMA_MODEL_REASONING=qwen3:4b-thinking
OLLAMA_MODEL_TAGGER=qwen3:4b-thinking
OLLAMA_MODEL_PLANNER=qwen2.5-coder:14b
OLLAMA_MODEL_ANALYZER=qwen3:4b-thinking
OLLAMA_MODEL_RESPONDER=qwen2.5-coder:7b
OLLAMA_MODEL_SEARCH=qwen3:4b-thinking
OLLAMA_MODEL_MEMORY=qwen3:4b-thinking
OLLAMA_MODEL_EVALUATOR=qwen2.5:7b
OLLAMA_MODEL_SPECIALIST_PLANNER=qwen3:4b-thinking
OLLAMA_MODEL_SPECIALIST_TOOLING=qwen2.5-coder:7b
OLLAMA_MODEL_SPECIALIST_FILESYSTEM_RESEARCH=qwen2.5-coder:7b
OLLAMA_MODEL_SPECIALIST_INTENT_TAGGING=qwen3:4b-thinking
OLLAMA_MODEL_SPECIALIST_MEMORY_RETRIEVAL=qwen3:4b-thinking
OLLAMA_MODEL_SPECIALIST_WEB_RESEARCH=qwen3:4b-thinking
OLLAMA_MODEL_SPECIALIST_ANALYSIS=qwen3:4b-thinking
OLLAMA_MODEL_SPECIALIST_RESPONSE=qwen2.5-coder:7b
OLLAMA_MODEL_SPECIALIST_REVIEW_VERIFICATION=qwen3:4b-thinking
OLLAMA_MODEL_SPECIALIST_MEDIA_CONTROL=qwen2.5-coder:7b
OLLAMA_MODEL_SPECIALIST_BROWSER_INSPECTION=qwen3:4b-thinking
OLLAMA_MODEL_SPECIALIST_SCREEN_VISION=qwen3:4b-thinking
OLLAMA_MODEL_SPECIALIST_SHELL_EXECUTION=qwen2.5-coder:7b
OLLAMA_MODEL_SPECIALIST_AUDIO_NOTES=qwen3:4b-thinking
EMBEDDING_MODEL=nomic-embed-text

# To use OpenAI instead of Ollama, set LLM_PROVIDER=openai and configure:
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MODEL_FAST=
OPENAI_MODEL_REASONING=
OPENAI_MODEL_TAGGER=
OPENAI_MODEL_PLANNER=
OPENAI_MODEL_ANALYZER=
OPENAI_MODEL_RESPONDER=
OPENAI_MODEL_SEARCH=
OPENAI_MODEL_MEMORY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# To use Google Gemini, set LLM_PROVIDER=google or gemini and configure:
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_MODEL_FAST=
GOOGLE_MODEL_REASONING=
GOOGLE_MODEL_TAGGER=
GOOGLE_MODEL_PLANNER=
GOOGLE_MODEL_ANALYZER=
GOOGLE_MODEL_RESPONDER=
GOOGLE_MODEL_SEARCH=
GOOGLE_MODEL_MEMORY=
GOOGLE_EMBEDDING_MODEL=text-embedding-004

# To use Anthropic Claude, set LLM_PROVIDER=anthropic or claude and configure.
# Anthropic does not provide embeddings; keep EMBEDDING_PROVIDER on ollama, openai, google, or huggingface.
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MAX_TOKENS=4096
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MODEL_FAST=
ANTHROPIC_MODEL_REASONING=
ANTHROPIC_MODEL_TAGGER=
ANTHROPIC_MODEL_PLANNER=
ANTHROPIC_MODEL_ANALYZER=
ANTHROPIC_MODEL_RESPONDER=
ANTHROPIC_MODEL_SEARCH=
ANTHROPIC_MODEL_MEMORY=
ANTHROPIC_EMBEDDING_PROVIDER=ollama

# To use Hugging Face Inference Providers, set LLM_PROVIDER=huggingface or hf and configure:
HUGGINGFACE_BASE_URL=https://router.huggingface.co
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=openai/gpt-oss-20b:fastest
HUGGINGFACE_MODEL_FAST=
HUGGINGFACE_MODEL_REASONING=
HUGGINGFACE_MODEL_TAGGER=
HUGGINGFACE_MODEL_PLANNER=
HUGGINGFACE_MODEL_ANALYZER=
HUGGINGFACE_MODEL_RESPONDER=
HUGGINGFACE_MODEL_SEARCH=
HUGGINGFACE_MODEL_MEMORY=
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-mpnet-base-v2

# Optional: route embeddings through a different provider than generation.
# Useful for Anthropic, or to keep vector dimensions stable while trying different chat models.
EMBEDDING_PROVIDER=ollama

WEB_SEARCH_ENABLED=true
WEB_SEARCH_PROVIDERS=duckduckgo,google,reddit
WEB_SEARCH_TIMEOUT=15s
WEB_SEARCH_PER_SOURCE_BUDGET=3000
WEB_SEARCH_TOTAL_BUDGET=6000

WORKSPACE_SCAN_ENABLED=true
WORKSPACE_ROOT=/workspace
WORKSPACE_MAX_FILES=5000
WORKSPACE_CONTEXT_BUDGET=6000

STOP_ON_SUFFICIENT_CONTEXT=true
SUFFICIENT_CONTEXT_CHARS=1400
MEMORY_INFERENCE_ENABLED=true
MEMORY_INFERENCE_MAX_ITEMS=3
TOURNAMENT_ENABLED=true
TOURNAMENT_CHUNK_CHARS=2200
TOURNAMENT_SUMMARY_CHARS=750
TOURNAMENT_MAX_ROUNDS=4
TOURNAMENT_VERIFY_RELEVANCE=true

WORKER_COUNT=3
WORKER_POLL_INTERVAL=2s
REQUEST_TIMEOUT=90s
RETRIEVAL_LIMIT=8
CONTEXT_CHAR_BUDGET=4000
HALLUCINATION_RETRY_LIMIT=2
OMNI_EVALUATOR_THRESHOLD=70
OMNI_EVALUATOR_NUM_CTX=1024
# Optional explicit restart command chain for hallucination loops.
# Use "||" between fallbacks, for example:
# OLLAMA_RESTART_COMMAND=docker compose restart ollama || systemctl restart ollama
OLLAMA_RESTART_COMMAND=
OLLAMA_RESTART_TIMEOUT=20s
MIGRATE_ON_STARTUP=true
OMNIDEX_V3_ENABLED=true
OMNIDEX_SKILLS_ROOT=skills

# External execution agents for scrum cards (Config tab → Execution agent on each card)
# Project/card agent choice is stored in DB and overrides env defaults.
# API keys: prefer Admin → API secrets (DB); env vars are fallback.
# OMNI_ENABLE_CURSOR_ARCHITECT is optional when a Cursor API key is configured.
# CURSOR_API_KEY=
# OMNI_CURSOR_MODEL=composer-2.5
# When core runs in Docker, Cursor executes on the host via the bridge — node/npm must be on the host PATH:
# OMNI_CURSOR_NODE_BIN=/home/you/.local/share/mise/installs/node/VERSION/bin/node
# OMNI_CURSOR_NPM_BIN=/home/you/.local/share/mise/installs/node/VERSION/bin/npm
# OMNI_ENABLE_CODEX_ARCHITECT=true
# CODEX_API_KEY=
# OMNI_AGENT_STRICT=true

# Host workspace mounted read-only into /workspace for scan context.
# Use an absolute host path when core runs in Docker so terminal + browse resolve correctly.
# Example: HOST_WORKSPACE_PATH=/home/you/Projects/stack/omni
HOST_WORKSPACE_PATH=
